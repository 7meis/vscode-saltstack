{
        "name": "sls",
        "scopeName": "text.yaml.jinja",
	        "comment": "Salt SLS and Saltcheck in YAML with Jinja",
        "fileTypes": [ "sls" ],
	        "firstLineMatch": "^(#!py\\b|{% extends [\"'][^\"']+[\"'] %})",
        "patterns": [
	                {
	                        "begin": "\\A(#!py\\b.*$)",
	                        "beginCaptures": {
	                                "1": {
	                                        "name": "comment.line.number-sign.python"
	                                }
	                        },
	                        "end": "\\z",
	                        "contentName": "source.python",
	                        "patterns": [
	                                {
	                                        "include": "source.python"
	                                }
	                        ]
	                },
                {
                        "include": "source.jinja"
                },
                {
                        "include": "source.yaml"
                }
        ]
}