{
	"cmd.call": {
		"prefix": "cmd.call:",
		"body": [
			"cmd.call:",
			"  - name: ${1:test.ping}",
			"$0"
		],
		"description": "cmd.call:"
	},
	"cmd.mod_run_check": {
		"prefix": "cmd.mod_run_check:",
		"body": [
			"cmd.mod_run_check:",
			"$0"
		],
		"description": "cmd.mod_run_check:"
	},
	"cmd.run": {
		"prefix": "cmd.run:",
		"body": [
			"cmd.run:",
			"  - name: ${1:echo hello}",
			"  - cwd: ${2:/tmp}",
			"$0"
		],
		"description": "cmd.run:"
	},
	"cmd.script": {
		"prefix": "cmd.script:",
		"body": [
			"cmd.script:",
			"  - name: ${1:/tmp/script.sh}",
			"  - source: ${2:salt://scripts/script.sh}",
			"$0"
		],
		"description": "cmd.script:"
	},
	"cmd.wait": {
		"prefix": "cmd.wait:",
		"body": [
			"cmd.wait:",
			"  - name: ${1:systemctl reload nginx}",
			"$0"
		],
		"description": "cmd.wait:"
	},
	"cmd.wait_call": {
		"prefix": "cmd.wait_call:",
		"body": [
			"cmd.wait_call:",
			"  - name: ${1:test.ping}",
			"$0"
		],
		"description": "cmd.wait_call:"
	},
	"cmd.wait_script": {
		"prefix": "cmd.wait_script:",
		"body": [
			"cmd.wait_script:",
			"  - name: ${1:/tmp/script.sh}",
			"  - source: ${2:salt://scripts/script.sh}",
			"$0"
		],
		"description": "cmd.wait_script:"
	},
	"cmd.watch": {
		"prefix": "cmd.watch:",
		"body": [
			"cmd.watch:",
			"  - name: ${1:systemctl reload nginx}",
			"$0"
		],
		"description": "cmd.watch:"
	}
