{
    "standard test": {
        "prefix": [
            "sctest"
        ],
        "body": [
	            "${1:test_id}:",
            "  module_and_function: ${2:test.echo}",
            "  args:",
	            "    - ${3:should return}",
	            "  assertion: ${4|assertEqual,assertNotEqual,assertTrue,assertFalse,assertIn,assertNotIn,assertGreater,assertGreaterEqual,assertLess,assertLessEqual,assertEmpty,assertNotEmpty|}",
	            "  expected_return: ${5:should return}",
            "$0"
        ],
        "description": "basic saltcheck test"
    },
    "multi-assert test": {
        "prefix": [
            "sctest"
        ],
        "body": [
	            "${1:test_id}:",
            "  module_and_function: ${2:test.arg}",
            "  args:",
	            "    - ${3:should return}",
            "  kwargs:",
	            "    a: ${4:value1}",
            "  assertions:",
	            "    - assertion: ${5|assertEqual,assertNotEqual,assertTrue,assertFalse,assertIn,assertNotIn,assertGreater,assertGreaterEqual,assertLess,assertLessEqual,assertEmpty,assertNotEmpty|}",
	            "      assertion_section: ${6:kwargs:a}",
	            "      expected_return: ${7:value1}",
	            "    - assertion: ${8|assertEqual,assertNotEqual,assertTrue,assertFalse,assertIn,assertNotIn,assertGreater,assertGreaterEqual,assertLess,assertLessEqual,assertEmpty,assertNotEmpty|}",
	            "      assertion_section: ${9:args}",
	            "      expected_return: ${10:should return}",
            "$0"
        ],
        "description": "saltcheck test with multiple assertions"
    }
}
